{
    "manifest_version": 2,
    "name": "microtask",
    "description": "micro gig remote desktop remote work",
    "version": "0.1",
    "author": "Kevin Kwok",
    "icons": {
        "128": "icon.png"
    },
    "browser_action": {
        "default_icon": {
            "128": "icon.png"
        },
        "default_title": "microtask"
    },
    "background": {
        "persistent": false,
        "scripts": ["lib/chrome-extension-async.js", "lib/simplepeer.min.js", "background.js"]
    },
    "permissions": ["tabs", "tabCapture", "activeTab", "debugger"],
    "web_accessible_resources": ["icon.png"]
}
